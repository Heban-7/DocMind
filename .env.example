# DocMind environment configuration (copy to .env and fill in)
# ==============================================================================
# You only need ONE provider key to enable the LLM/VLM features. OpenRouter is
# the easiest ("one key, any model"); direct providers are cheaper/faster.

# --- LLM provider API keys (set at least one) --------------------------------
# OpenRouter: single key, swap to almost any model by name. Recommended default.
OPENROUTER_API_KEY=
# Direct providers:
OPENAI_API_KEY=
GEMINI_API_KEY=
# (GOOGLE_API_KEY is also accepted for Gemini.)
GROQ_API_KEY=

# --- Model selection ---------------------------------------------------------
# Force a provider (optional): openrouter | openai | gemini | groq
# If unset, the system auto-detects by whichever key is present.
LLM_PROVIDER=
# Force a model by friendly name (see rubric/models.yaml) or a raw slug, e.g.:
#   gemini-flash | gpt-4o-mini | or-gemini-flash | google/gemini-2.0-flash-001
LLM_MODEL=
# Separate (cheap) model for text tasks like domain classification.
# Defaults to the registry's `defaults.text` (gemini-flash) when unset.
LLM_TEXT_MODEL=

# Path to the model registry (optional override).
# DOCMIND_MODEL_REGISTRY=rubric/models.yaml

# --- Phase 4: embeddings + retrieval (OpenAI) --------------------------------
# Requires OPENAI_API_KEY above. Used to turn LDUs into vectors for ChromaDB.
# DOCMIND_EMBEDDING_PROVIDER=openai
# DOCMIND_EMBEDDING_MODEL=text-embedding-3-small
# Optional: shrink stored vector size (OpenAI supports Matryoshka dims), e.g. 512
# DOCMIND_EMBEDDING_DIMS=
# DOCMIND_EMBEDDING_BATCH=64
# DOCMIND_CHROMA_COLLECTION=docmind_ldus
# DOCMIND_CHROMA_DIR=.refinery/chroma
# DOCMIND_FACTS_DB=.refinery/facts.db
# Conversation memory (LangGraph SqliteSaver); used with run_query.py --memory/--thread
# DOCMIND_CHECKPOINTS_DB=.refinery/checkpoints.sqlite

# --- LangSmith observability (STEP 3) ----------------------------------------
# Create an API key at https://smith.langchain.com -> Settings -> API Keys
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=docmind

# --- Extraction acceleration (optional overrides) ----------------------------
# Compute device: auto | cuda | mps | cpu   (auto picks GPU when available)
# DOCMIND_DEVICE=auto
# DOCMIND_NUM_THREADS=8
# DOCMIND_PAGE_BATCH_GPU=8
# DOCMIND_PAGE_BATCH_CPU=2
# DOCMIND_TABLE_MODE=fast

# --- OCR (Amharic-aware) -----------------------------------------------------
# Engine: auto | tesseract | easyocr   (Tesseract is required for Amharic)
# DOCMIND_OCR_ENGINE=auto
# DOCMIND_OCR_LANGS=amh+eng
